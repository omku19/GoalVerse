{
  "name": "goalverse",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack monorepo with React, Vite, Tailwind CSS, Express, Prisma, and PostgreSQL.",
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:frontend:fresh": "npm run dev:fresh --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "render:build": "npm run prisma:generate --workspace backend && npm run prisma:migrate:deploy --workspace backend",
    "start": "npm run start --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace backend"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}
